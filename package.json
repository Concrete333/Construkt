{
  "name": "construkt",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "anchor:test": "anchor test --provider.cluster localnet",
    "anchor:test:wsl": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/wsl-anchor-test.ps1",
    "seed:localnet": "ts-node -P tsconfig.scripts.json scripts/seed-localnet.ts",
    "seed:localnet:wsl": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/seed-localnet-wsl.ps1",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json",
    "test:frontend": "ts-mocha -p ./tsconfig.json -t 10000 \"frontend-prototype/tests/construkt.frontend.ts\"",
    "lint": "prettier \"migrations/**/*.ts\" \"tests/**/*.ts\" --check",
    "lint:fix": "prettier \"migrations/**/*.ts\" \"tests/**/*.ts\" -w"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "@types/node": "^24.12.3",
    "chai": "^4.3.4",
    "mocha": "^11.7.5",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
